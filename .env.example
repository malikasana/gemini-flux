# Gemini API Keys — one per line, add as many as you have
# Get keys from: https://console.cloud.google.com -> APIs & Services -> Credentials
GEMINI_KEY_1=your_key_1
GEMINI_KEY_2=your_key_2
GEMINI_KEY_3=your_key_3
GEMINI_KEY_4=your_key_4
GEMINI_KEY_5=your_key_5
GEMINI_KEY_6=your_key_6
GEMINI_KEY_7=your_key_7
GEMINI_KEY_8=your_key_8

# Model mode: both, pro_only, flash_only
GEMINI_MODE=both

# Console logging: true or false
GEMINI_LOG=true